    <!-- ========== SECTIONS ========== -->
    <section id="networking-concepts" platform="ocp">
      <title>Networking concepts</title>
      <p>Cluster networking uses <codeph>OVN-Kubernetes</codeph> by default.</p>
      <note type="restriction" audience="developer">Developers cannot modify
        cluster network settings.</note>
      <simpletable>
        <sthead>
          <stentry>Network type</stentry>
          <stentry>Plugin</stentry>
        </sthead>
        <strow>
          <stentry>Cluster</stentry>
          <stentry><codeph>OVN-Kubernetes</codeph></stentry>
        </strow>
      </simpletable>
    </section>

    <section id="storage-concepts" product="odf">
      <title>Storage concepts</title>
      <p>Persistent volumes provide durable storage.</p>
      <dl>
        <dlentry>
          <dt>PV</dt>
          <dd>PersistentVolume — cluster-level storage resource.</dd>
        </dlentry>
        <dlentry>
          <dt>PVC</dt>
          <dd>PersistentVolumeClaim — a request for storage.</dd>
        </dlentry>
      </dl>
      <codeblock outputclass="language-yaml">apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: data-pvc
spec:
  accessModes: ["ReadWriteOnce"]
  resources:
    requests:
      storage: 10Gi</codeblock>
    </section>


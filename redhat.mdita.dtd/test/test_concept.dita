<concept id="test-concept">
  <title>MDITA Concept Validation Test</title>
  <shortdesc>Exercises all elements permitted in the MDITA concept shell,
    including prolog, every block and inline element in conbody, sections,
    and profiling attributes.</shortdesc>
  <prolog>
    <metadata>
      <audience type="administrator"/>
      <category>Infrastructure</category>
      <keywords>
        <keyword>concept</keyword>
        <keyword>architecture</keyword>
      </keywords>
    </metadata>
    <data name="author" value="Validation Suite"/>
    <data name="category" value="concepts"/>
  </prolog>
  <conbody>

    <!-- ========== PARAGRAPHS WITH ALL INLINE ELEMENTS ========== -->
    <p>Highlight domain: <b>bold</b>, <i>italic</i>, <u>underline</u>,
       <sub>subscript</sub>, <sup>superscript</sup>, <tt>teletype</tt>,
       <line-through>strikethrough</line-through>.</p>
    <p>Programming domain: <codeph>kubectl apply</codeph>,
       <apiname>Deployment</apiname>, <option>--dry-run</option>.</p>
    <p>Software domain: <cmdname>podman</cmdname>,
       <varname>$REGISTRY_URL</varname>.</p>
    <p>UI domain: <uicontrol>Apply</uicontrol>,
       <menucascade><uicontrol>Settings</uicontrol><uicontrol>Network</uicontrol></menucascade>,
       <wintitle>Preferences</wintitle>.</p>
    <p>More inline: <filepath>/opt/app/config.yaml</filepath>,
       <systemoutput>200 OK</systemoutput>,
       <userinput>curl -k https://api.example.com</userinput>,
       <msgph>WARN-1002</msgph>.</p>
    <p>Structural inline: <cite>The Twelve-Factor App</cite>,
       <ph>a phrase element</ph>,
       <keyword>container</keyword>,
       <keyword keyref="product-name"/>,
       <xref href="https://kubernetes.io" format="html" scope="external">Kubernetes docs</xref>.</p>

    <!-- ========== DATA IN BODY ========== -->
    <data name="component" value="networking"/>

    <!-- ========== NOTE TYPES ========== -->
    <note>Default note in concept.</note>

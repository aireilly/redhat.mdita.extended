    <topicref href="test_concept.dita"/>
    <topicref href="test_task.dita"/>
    <topicref href="test_reference.dita"/>
  </topicref>

  <!-- ========== KEYDEFS: keyword content ========== -->
  <keydef keys="product-name">
    <topicmeta>
      <keywords>
        <keyword>Red Hat OpenShift Container Platform</keyword>
      </keywords>
    </topicmeta>
  </keydef>
  <keydef keys="product-short">
    <topicmeta>
      <keywords>
        <keyword>OpenShift</keyword>
      </keywords>
    </topicmeta>
  </keydef>
  <keydef keys="version">
    <topicmeta>
      <keywords>
        <keyword>4.15</keyword>
      </keywords>
    </topicmeta>
  </keydef>

  <!-- ========== KEYDEFS: href-based ========== -->
  <keydef keys="product-url" href="https://www.redhat.com/openshift"
          format="html" scope="external"/>
  <keydef keys="install-guide" href="test_task.dita"/>

  <!-- ========== MAPREF ========== -->
  <mapref href="other.ditamap"/>
  <mapref href="sub-map.ditamap" platform="ocp"/>

  <!-- ========== RELTABLE WITH HEADER ========== -->
  <reltable>
    <relheader>
      <relcolspec type="concept"/>
      <relcolspec type="task"/>
      <relcolspec type="reference"/>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE map PUBLIC "-//RED HAT//DTD MDITA 2.0 Map//EN" "mditaMap.dtd">
<map>
  <title>MDITA Map Validation Test</title>
  <topicmeta>
    <data name="category" value="validation"/>
    <data name="version" value="2.0"/>
  </topicmeta>

  <!-- ========== SIMPLE TOPICREFS ========== -->
  <topicref href="test_topic.dita"/>
  <topicref href="test_concept.dita" type="concept"/>

  <!-- ========== TOPICREF WITH ATTRIBUTES ========== -->
  <topicref href="test_task.dita" type="task" platform="ocp"/>
  <topicref href="test_reference.dita" type="reference" audience="admin"/>
  <topicref href="https://docs.openshift.com" format="html" scope="external"
            product="ocp"/>

  <!-- ========== TOPICHEAD WITH NESTED CHILDREN ========== -->
  <topichead>
    <topicmeta>
      <titlealt title-role="navigation">Installation Guide</titlealt>
    </topicmeta>
    <topicref href="test_concept.dita">
      <topicmeta>
        <data name="chapter" value="1"/>
      </topicmeta>
    </topicref>
    <topicref href="test_task.dita">
      <topicref href="test_reference.dita"/>
    </topicref>
  </topichead>

  <!-- ========== NESTED TOPICREFS (DEEP NESTING) ========== -->
  <topicref href="test_topic.dita">
    <topicref href="test_concept.dita">
      <topicref href="test_reference.dita"/>
    </topicref>
  </topicref>

  <!-- ========== TOPICHEAD WITH MIXED NESTING ========== -->
  <topichead>
    <topicmeta>
      <titlealt title-role="navigation">Administration</titlealt>
    </topicmeta>
    <topichead>
      <topicmeta>
        <titlealt title-role="navigation">Monitoring</titlealt>
      </topicmeta>
      <topicref href="test_task.dita"/>
    </topichead>
    <topicref href="test_reference.dita"/>
  </topichead>

  <!-- ========== COLLECTION-TYPE SEQUENCE ========== -->

<task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/"
      class="- topic/topic task/task "
      ditaarch:DITAArchVersion="2.0"
      id="task"
      specializations="@props/audience @props/deliveryTarget @props/otherprops @props/platform @props/product">
   <title class="- topic/title ">Task</title>
   <taskbody class="- topic/body task/taskbody ">
      <steps class="- topic/ol task/steps ">
         <step class="- topic/li task/step ">
            <cmd class="- topic/ph task/cmd ">Select an option:</cmd>
            <info class="- topic/itemgroup task/info ">
               <simpletable class="- topic/simpletable ">
                  <sthead class="- topic/sthead ">
                     <stentry class="- topic/stentry ">Option</stentry>
                     <stentry class="- topic/stentry ">Description</stentry>
                  </sthead>
                  <strow class="- topic/strow ">
                     <stentry class="- topic/stentry ">Fast</stentry>
                     <stentry class="- topic/stentry ">Quick setup</stentry>
                  </strow>
                  <strow class="- topic/strow ">
                     <stentry class="- topic/stentry ">Full</stentry>
                     <stentry class="- topic/stentry ">Complete install</stentry>
                  </strow>
               </simpletable>
            </info>
         </step>
      </steps>
   </taskbody>
</task>

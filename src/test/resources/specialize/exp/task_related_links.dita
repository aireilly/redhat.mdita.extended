<task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/"
      class="- topic/topic task/task "
      ditaarch:DITAArchVersion="2.0"
      id="task-related-links"
      specializations="@props/audience @props/deliveryTarget @props/otherprops @props/platform @props/product">
   <title class="- topic/title ">Install the software</title>
   <taskbody class="- topic/body task/taskbody ">
      <steps class="- topic/ol task/steps ">
         <step class="- topic/li task/step ">
            <cmd class="- topic/ph task/cmd ">Run the installer.</cmd>
         </step>
      </steps>
      <result class="- topic/section task/result ">
         <section class="- topic/section " outputclass="related-links">
            <title class="- topic/title ">Related information</title>
            <ul class="- topic/ul ">
               <li class="- topic/li ">
                  <p class="- topic/p ">
                     <xref class="- topic/xref " href="reference.dita">Widget reference</xref>
                  </p>
               </li>
               <li class="- topic/li ">
                  <p class="- topic/p ">
                     <xref class="- topic/xref "
                           format="html"
                           href="https://example.com"
                           scope="external">Online docs</xref>
                  </p>
               </li>
            </ul>
         </section>
      </result>
   </taskbody>
</task>

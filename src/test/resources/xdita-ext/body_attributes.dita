<?xml version="1.0" encoding="UTF-8"?>
<topic xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/" class="- topic/topic "
       ditaarch:DITAArchVersion="2.0" id="header" specializations="(topic hi-d)(topic em-d) @props/audience @props/deliveryTarget @props/otherprops @props/platform @props/product">
  <title class="- topic/title ">Header</title>
  <shortdesc class="- topic/shortdesc ">Paragraph</shortdesc>
  <body class="- topic/body ">
    <p class="- topic/p ">Inline <b class="+ topic/ph hi-d/b " outputclass="red">bold</b>.</p>
    <p class="- topic/p ">Inline <i class="+ topic/ph hi-d/i " outputclass="red">inline</i>.</p>
    <p class="- topic/p " outputclass="red">Quote</p>
    <ul audience="novice" class="- topic/ul ">
      <li class="- topic/li ">
        <p class="- topic/p " id="ul">List item</p>
      </li>
      <li class="- topic/li ">
        <p class="- topic/p ">List item</p>
      </li>
    </ul>
    <ol audience="novice" class="- topic/ol ">
      <li class="- topic/li ">
        <p class="- topic/p " id="ol">List item</p>
      </li>
      <li class="- topic/li ">
        <p class="- topic/p ">List item</p>
      </li>
    </ol>
    <dl audience="novice" class="- topic/dl ">
      <dlentry class="- topic/dlentry ">
        <dt class="- topic/dt ">Definition Term</dt>
        <dd class="- topic/dd ">
          <p class="- topic/p " outputclass="red">definition item 1</p>
        </dd>
        <dd class="- topic/dd ">
          <p class="- topic/p ">definition item 2</p>
        </dd>
      </dlentry>
    </dl>
    <simpletable audience="novice" class="- topic/simpletable ">
      <sthead class="- topic/sthead ">
        <stentry class="- topic/stentry ">head</stentry>
      </sthead>
      <strow class="- topic/strow ">
        <stentry class="- topic/stentry ">
          <p class="- topic/p ">body</p>
        </stentry>
      </strow>
    </simpletable>
    <pre audience="novice" class="- topic/pre " id="id" outputclass="lang" xml:space="preserve"><tt class="+ topic/ph hi-d/tt ">code</tt></pre>
    <fig class="- topic/fig ">
      <title class="- topic/title ">Title</title>
      <image class="- topic/image " href="test.jpg" id="carrot" outputclass="juice">
        <alt class="- topic/alt ">Alt</alt>
      </image>
    </fig>
    <image class="- topic/image " id="key-carrot" keyref="img_id" outputclass="juice" placement="break"/>
  </body>
</topic>

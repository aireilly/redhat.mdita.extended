<topic xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/"
       class="- topic/topic "
       ditaarch:DITAArchVersion="2.0"
       id="domain-elements"
       specializations="(topic hi-d)(topic em-d)(topic ui-d)(topic sw-d)(topic pr-d) @props/audience @props/deliveryTarget @props/otherprops @props/platform @props/product">
   <title class="- topic/title ">Domain elements</title>
   <shortdesc class="- topic/shortdesc ">Click <b class="+ topic/ph hi-d/b ">Save</b> to save the file.</shortdesc>
   <body class="- topic/body ">
      <p class="- topic/p ">The <b class="+ topic/ph hi-d/b ">Dashboard</b> window opens.</p>
      <p class="- topic/p ">Navigate to <b class="+ topic/ph hi-d/b ">File &gt; Open &gt; Recent</b> to see recent files.</p>
      <p class="- topic/p ">Edit the <tt class="+ topic/ph hi-d/tt ">config.yaml</tt> file.</p>
      <p class="- topic/p ">Run the <tt class="+ topic/ph hi-d/tt ">ansible-playbook</tt> command.</p>
      <p class="- topic/p ">Enter <tt class="+ topic/ph hi-d/tt ">admin</tt> as the username.</p>
      <p class="- topic/p ">The system returns <tt class="+ topic/ph hi-d/tt ">OK</tt>.</p>
      <p class="- topic/p ">Set the <tt class="+ topic/ph hi-d/tt ">verbose</tt> option.</p>
      <p class="- topic/p ">Use the <tt class="+ topic/ph hi-d/tt ">inventory</tt> parameter.</p>
      <p class="- topic/p ">Call the <tt class="+ topic/ph hi-d/tt ">getHosts</tt> API.</p>
      <p class="- topic/p ">Set the <tt class="+ topic/ph hi-d/tt ">MAX_RETRIES</tt> variable.</p>
      <p class="- topic/p ">Check the <tt class="+ topic/ph hi-d/tt ">ERR_TIMEOUT</tt> message.</p>
      <p class="- topic/p ">Use <tt class="+ topic/ph hi-d/tt ">codeph</tt> for code phrases.</p>
      <p class="- topic/p ">See <i class="+ topic/ph hi-d/i ">Ansible Automation Platform Planning Guide</i> for details.</p>
      <p class="- topic/p ">This needs review.</p>
   </body>
</topic>

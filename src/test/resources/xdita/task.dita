<task xmlns:ditaarch="http://dita.oasis-open.org/architecture/2005/"
      class="- topic/topic task/task "
      ditaarch:DITAArchVersion="2.0"
      id="task"
      specializations="@props/audience @props/deliveryTarget @props/otherprops @props/platform @props/product">
   <title class="- topic/title ">Task</title>
   <shortdesc class="- topic/shortdesc ">Context</shortdesc>
   <prolog class="- topic/prolog "/>
   <taskbody class="- topic/body task/taskbody ">
      <steps class="- topic/ol task/steps ">
         <step class="- topic/li task/step ">
            <cmd class="- topic/ph task/cmd ">Command</cmd>
            <info class="- topic/itemgroup task/info ">
               <p class="- topic/p ">Info.</p>
            </info>
         </step>
         <step class="- topic/li task/step ">
            <cmd class="- topic/ph task/cmd ">
               <b class="+ topic/ph hi-d/b ">Command</b>
            </cmd>
            <info class="- topic/itemgroup task/info ">
               <p class="- topic/p ">Info.</p>
            </info>
         </step>
         <step class="- topic/li task/step ">
            <cmd class="- topic/ph task/cmd ">
               <b class="+ topic/ph hi-d/b ">Command</b> tail</cmd>
            <info class="- topic/itemgroup task/info ">
               <p class="- topic/p ">Info.</p>
            </info>
         </step>
         <step class="- topic/li task/step ">
            <cmd class="- topic/ph task/cmd ">head <b class="+ topic/ph hi-d/b ">Command</b>
            </cmd>
            <info class="- topic/itemgroup task/info ">
               <p class="- topic/p ">Info.</p>
            </info>
         </step>
         <step class="- topic/li task/step ">
            <cmd class="- topic/ph task/cmd ">head <b class="+ topic/ph hi-d/b ">Command</b> tail</cmd>
            <info class="- topic/itemgroup task/info ">
               <p class="- topic/p ">Info.</p>
            </info>
         </step>
         <step class="- topic/li task/step ">
            <cmd class="- topic/ph task/cmd ">Command</cmd>
         </step>
         <step class="- topic/li task/step ">
            <cmd class="- topic/ph task/cmd ">
               <b class="+ topic/ph hi-d/b ">Command</b>
            </cmd>
         </step>
         <step class="- topic/li task/step ">
            <cmd class="- topic/ph task/cmd ">
               <b class="+ topic/ph hi-d/b ">Command</b> tail</cmd>
         </step>
         <step class="- topic/li task/step ">
            <cmd class="- topic/ph task/cmd ">head <b class="+ topic/ph hi-d/b ">Command</b>
            </cmd>
         </step>
         <step class="- topic/li task/step ">
            <cmd class="- topic/ph task/cmd ">head <b class="+ topic/ph hi-d/b ">Command</b> tail</cmd>
         </step>
      </steps>
   </taskbody>
</task>
